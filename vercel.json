{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/tournament_hub.html"
    },
    {
      "source": "/calendar",
      "destination": "/calendar.html"
    },
    {
      "source": "/index.html",
      "destination": "/calendar.html"
    },
    {
      "source": "/agenda",
      "destination": "/agenda.html"
    },
    {
      "source": "/tournaments",
      "destination": "/tournaments.html"
    },
    {
      "source": "/calendar-ics-links.html",
      "destination": "/calendar-ics-links.html"
    }
  ],
  "crons": [
    {
      "path": "/api/sync-links",
      "schedule": "0 0 * * *"
    }
  ]
}